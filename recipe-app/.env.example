# Recipe app — point these at your Cloudflare Workers (or use .env.development with staging URLs).

# Recipe save worker: GET /api/recipes/:id, POST /save
VITE_API_URL=https://your-recipe-save-worker.your-subdomain.workers.dev

# Search worker: GET /api/search?q=...&type=recipe&limit=10
VITE_SEARCH_DB_URL=https://your-recipe-search-db.your-subdomain.workers.dev

# Clipper worker: POST /clip
VITE_CLIPPER_API_URL=https://your-clipper-worker.your-subdomain.workers.dev

# Recipe generation worker: POST /generate
VITE_RECIPE_GENERATION_URL=https://your-recipe-generation-worker.your-subdomain.workers.dev

# Recipe view worker: GET /recipe/:id — serves shareable recipe pages
VITE_RECIPE_VIEW_URL=https://your-recipe-view-worker.your-subdomain.workers.dev

# Auth worker: POST /otp/generate, POST /otp/verify, POST /auth/validate, POST /auth/refresh
VITE_AUTH_WORKER_URL=https://your-auth-worker.your-subdomain.workers.dev

# ── Flaggly (Cloudflare Pages / wrangler secrets; not VITE_*) ─────────────────
# Set FLAGGLY_API_KEY on the **recipe Pages project** (the one that deploys this app + src/worker.js),
# not only on the Flaggly worker. The Pages worker reads the secret and injects it when calling Flaggly.
#
# FLAGGLY_API_KEY must be the **user** JWT from your Flaggly worker:
#   curl -X POST "https://YOUR-FLAGGLY.workers.dev/__generate" \
#     -H "Content-Type: application/json" \
#     -d '{"secret":"YOUR_JWT_SECRET"}'
# Use the `user` string in the JSON response (iss: flaggly.user). Not the `admin` token, not JWT_SECRET.
#   wrangler secret put FLAGGLY_API_KEY
#
# Local dev (`npm run dev`): Vite has no Pages worker, so either use `wrangler pages dev` or set both:
#   FLAGGLY_EVAL_URL=https://YOUR-FLAGGLY.workers.dev
#   FLAGGLY_USER_JWT=<same `user` JWT as above>
# (in .env.development.local — loaded by vite.config.js proxy only, not bundled into the client)
#
# If your flags live under another app/env in Flaggly (KV key v1:{app}:{env}):
#   VITE_FLAGGLY_APP_ID=my-app
#   VITE_FLAGGLY_ENV_ID=staging
# Match the same app/env in FLAGGLY_APP_ID / FLAGGLY_ENV_ID for the dev proxy headers.
