# Recipe app — point these at your Cloudflare Workers (or use .env.development with staging URLs).

# Recipe save worker: GET /api/recipes/:id, POST /save
VITE_API_URL=https://your-recipe-save-worker.your-subdomain.workers.dev

# Search worker: GET /api/search?q=...&type=recipe&limit=10
VITE_SEARCH_DB_URL=https://your-recipe-search-db.your-subdomain.workers.dev

# Clipper worker: POST /clip
VITE_CLIPPER_API_URL=https://your-clipper-worker.your-subdomain.workers.dev

# Recipe generation worker: POST /generate
VITE_RECIPE_GENERATION_URL=https://your-recipe-generation-worker.your-subdomain.workers.dev

# Recipe view worker: GET /recipe/:id — serves shareable recipe pages
VITE_RECIPE_VIEW_URL=https://your-recipe-view-worker.your-subdomain.workers.dev
