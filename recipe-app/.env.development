# Recipe app — development defaults (staging workers). Copy to .env.local to override.

# Recipe save worker (handles /api/recipes/:id and /save)
VITE_API_URL=https://staging-recipe-save-worker.nolanfoster.workers.dev

# Search worker
VITE_SEARCH_DB_URL=https://staging-recipe-search-db.nolanfoster.workers.dev

# Clipper worker
VITE_CLIPPER_API_URL=https://staging-clipper.nolanfoster.workers.dev

# Recipe generation worker
VITE_RECIPE_GENERATION_URL=https://recipe-generation-worker-staging.nolanfoster.workers.dev
